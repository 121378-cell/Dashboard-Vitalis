# ⚠️  Copia este archivo a backend/.env y completa con tus valores
#     Nunca subas .env a git (está en .gitignore)

# ─── Encryption ──────────────────────────────────────────────
# Clave Fernet para cifrar credenciales sensibles en BD (Garmin, etc.)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: Una vez configurada NO CAMBIAR, o los datos cifrados no podrán descifrarse.
FERNET_KEY=

# ─── Garmin Credentials ──────────────────────────────────────
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Garmin OAuth (optional)
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GARMIN_REDIRECT_URI=http://localhost:3000/auth/garmin/callback

# ─── AI Provider Keys ────────────────────────────────────────
VITE_GROQ_API_KEY=
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3
VITE_GEMINI_API_KEY=your_gemini_api_key

# ─── Strava OAuth2 ───────────────────────────────────────────
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:8001/api/v1/strava/callback

# ─── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
